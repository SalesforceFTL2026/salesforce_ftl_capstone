      "hurricane": {
        "title": "飓风与洪水",
        "before": {
          "0": "了解你的疏散区域和路线。",
          "1": "准备应急包：3 天的饮用水（每人每天 1 加仑）、非易腐食物、药品、手电筒、电池。",
          "2": "将证件（身份证、保险、医疗）放在防水袋中。",
          "3": "为手机和备用电池充电；给你的汽车加满油。"
        },
        "during": {
          "0": "如被要求疏散，请立即撤离。切勿驶过洪水——“掉头，别淹没（Turn Around, Don’t Drown）”。",
          "1": "移动到建筑物的最高层；避开地下室。",
          "2": "远离窗户；在室内房间中避难。",
          "3": "用电池或手摇收音机收听当地官员的信息。"
        },
        "after": {
          "0": "只有当当局宣布安全后才返回家中。",
          "1": "避开积水——它可能带电或已被污染。",
          "2": "在清理前拍摄损失照片以供保险理赔。",
          "3": "查看邻居的情况，尤其是老年人和残障人士。"
        }
      },
      "wildfire": {
        "title": "野火",
        "before": {
          "0": "清除住宅周围 30 英尺内的落叶、灌木和杂物。",
          "1": "准备一个应急包并放在门边。",
          "2": "订阅当地紧急警报。",
          "3": "规划两条离开你所在社区的逃生路线。"
        },
        "during": {
          "0": "尽早撤离——如果你感到不安全，不要等到接到疏散命令。",
          "1": "佩戴 N95 口罩；离开前关闭所有门窗。",
          "2": "如果被困，拨打 911 并在远离植被的清空区域避难。",
          "3": "打开车头灯；在烟雾中缓慢行驶。"
        },
        "after": {
          "0": "在收到“解除警报”之前不要返回。",
          "1": "警惕余火热点、灰坑和掉落的电线。",
          "2": "清理时佩戴手套和口罩；灰烬可能有毒。",
          "3": "记录损失以供保险和 FEMA 理赔。"
        }
      },
      "earthquake": {
        "title": "地震",
        "before": {
          "0": "将笨重的家具、热水器和架子固定在墙上。",
          "1": "找出安全地点：坚固的桌子下方、靠内墙处。",
          "2": "在床边放一双结实的鞋和一支手电筒。",
          "3": "储备应急包，并了解如何关闭燃气和水源。"
        },
        "during": {
          "0": "趴下、遮挡、抓牢（Drop, Cover, and Hold On）——躲到坚固的家具下方。",
          "1": "在震动停止前留在室内；不要跑到室外。",
          "2": "如果在室外，移动到远离建筑物和电线的开阔地带。",
          "3": "如果在驾车，靠边停车，远离立交桥并停下。"
        },
        "after": {
          "0": "预防余震；如果余震来临，再次趴下、遮挡、抓牢。",
          "1": "检查是否有人受伤以及是否有燃气泄漏——如果闻到燃气味，立即离开。",
          "2": "使用短信而非通话，以保持电话线路畅通。",
          "3": "在重新进入前检查你的住宅是否受损。"
        }
      },
      "tornado": {
        "title": "龙卷风",
        "before": {
          "0": "了解区别：警戒（Watch）意味着可能发生；警报（Warning）意味着立即避难。",
          "1": "确定一个安全房间——地下室或最低楼层的室内房间。",
          "2": "准备头盔或厚毯子以保护头部。",
          "3": "在你的手机上启用无线紧急警报。"
        },
        "during": {
          "0": "立即前往你的安全房间；在你和外界之间尽可能多隔几堵墙。",
          "1": "护住你的头部和颈部；蹲低身子。",
          "2": "避开窗户、门和外墙。",
          "3": "如果在移动房屋或车内，请前往坚固的建筑物。"
        },
        "after": {
          "0": "警惕碎玻璃、钉子和掉落的电线。",
          "1": "在受损建筑物经过检查前不要进入。",
          "2": "帮助受伤人员，但除非有危险，否则不要移动重伤者。",
          "3": "拍摄损失照片以供保险理赔。"
        }
      },
      "winter": {
        "title": "冬季风暴",
        "before": {
          "0": "为管道保温，并了解如果管道结冰如何关闭水源。",
          "1": "储备额外的毯子、保暖衣物、食物和水。",
          "2": "准备好手电筒和电池以应对停电。",
          "3": "检修供暖设备，并检查烟雾/一氧化碳探测器。"
        },
        "during": {
          "0": "留在室内并穿多层衣物。",
          "1": "切勿在室内使用发电机、烤架或野营炉——存在一氧化碳中毒风险。",
          "2": "让水龙头稍微滴水以防止管道结冰。",
          "3": "如果失去供暖，关闭不使用的房间以保存暖气。"
        },
        "after": {
          "0": "查看有受冻风险的邻居的情况。",
          "1": "警惕冻伤和体温过低的迹象。",
          "2": "清除通风口和排气口的积雪，以避免一氧化碳积聚。",
          "3": "铲雪时避免过度劳累。"
        }
      },
      "heat": {
        "title": "极端高温",
        "before": {
          "0": "找出有空调的公共场所（图书馆、商场、纳凉中心）。",
          "1": "检查风扇和空调是否正常；遮挡上午/下午被太阳照射的窗户。",
          "2": "储备额外的水和电解质饮料。",
          "3": "计划查看年长或独居邻居的情况。"
        },
        "during": {
          "0": "经常喝水——不要等到口渴才喝。",
          "1": "待在家中最凉爽的地方或纳凉中心。",
          "2": "切勿将人或宠物留在停放的车内。",
          "3": "将户外活动限制在清晨或傍晚。"
        },
        "after": {
          "0": "警惕中暑衰竭（大量出汗、虚弱）和热射病（意识模糊、皮肤又热又干——拨打 911）。",
          "1": "继续在凉爽的地方补水和休息。",
          "2": "查看家人、邻居和宠物的情况。",
          "3": "为下一波高温补充你的水和物资。"
        }
      }
