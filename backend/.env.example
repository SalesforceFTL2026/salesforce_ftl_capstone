# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mapresponse"

# AI APIs
ANTHROPIC_API_KEY="sk-ant-your-key-here"
OPENAI_API_KEY="sk-your-key-here"
COHERE_API_KEY="your-cohere-key-here"

# OpenRouter — powers the Mappie chat assistant (services/ai/chatbot.js).
# Each teammate makes their OWN free key (no shared key, no credits needed):
#   1. Sign up at https://openrouter.ai
#   2. Create a key at https://openrouter.ai/keys
#   3. Paste it below in your local .env (never commit the real value)
OPENROUTER_API_KEY="sk-or-your-key-here"

# Google Gemini — free fallback for chat/voice extraction when OpenRouter's
# free daily quota (50 req/day) is exhausted. Separate quota, so it covers us
# when OpenRouter runs dry. Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY="your-google-ai-studio-key-here"

# Server
PORT=3000
NODE_ENV="development"

# Auth
# Secret used to sign login tokens (JWTs). Generate your own with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Never commit the real value — keep it only in .env
JWT_SECRET_KEY="your-long-random-secret-here"
